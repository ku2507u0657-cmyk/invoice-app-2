# ─────────────────────────────────────────────────────────────
#  InvoiceFlow — Environment Variables
#  Copy to .env and fill in values
# ─────────────────────────────────────────────────────────────

# Flask core
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production

# Database
DATABASE_URL=sqlite:///invoice_app.db

# App settings
APP_NAME=InvoiceFlow
COMPANY_NAME=Your Company Ltd.

# ── Admin seed (development only) ─────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# ── Email / SMTP ───────────────────────────────────────────────
# Set MAIL_ENABLED=True to activate sending.
# Development default is False (no emails sent).
MAIL_ENABLED=False

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True

# For Gmail: use an App Password (not your account password).
# Generate one at: https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password

MAIL_FROM_NAME=InvoiceFlow
MAIL_FROM_ADDRESS=your-email@gmail.com

# Optional: send to this address when a client has no email set
MAIL_FALLBACK_RECIPIENT=

# ── APScheduler / Reminder ─────────────────────────────────────
# Master switch — set False to disable all scheduled jobs.
# Development default is False.
SCHEDULER_ENABLED=False

# Time of day for the daily overdue-reminder job (24-hour clock).
REMINDER_HOUR=9
REMINDER_MINUTE=0

# IANA timezone for scheduling, e.g. Asia/Kolkata, US/Eastern, UTC
SCHEDULER_TIMEZONE=UTC

# Days past due before the first reminder fires (0 = day of expiry).
REMINDER_GRACE_DAYS=0
